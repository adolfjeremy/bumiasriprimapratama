---
import tommy from "../assets/images/tommy.png";
import heri from "../assets/images/heri.png";
import sahriza from "../assets/images/sahriza.png";
import tulus from "../assets/images/tulus.png";
import sonia from "../assets/images/sonia.png";
import anggoro from "../assets/images/anggoro.png";
import faqih from "../assets/images/faqih.png";
import yehezkiel from "../assets/images/yehezkiel.png";
---

<div class="chart-wrapper w-full max-w-5xl mx-auto">
    <svg viewBox="0 0 750 1000" class="w-full h-auto overflow-visible">
        <defs>
            <style>
                .line {
                    stroke: #1e293b;
                    stroke-width: 4;
                }

                .box {
                    fill: #0f2e4d;
                    transition: transform 0.25s ease, filter 0.25s ease;
                    transform-box: fill-box;
                    transform-origin: center;
                    cursor: pointer;
                }

                .box:hover {
                    transform: scale(1.05);
                    filter: drop-shadow(0px 12px 24px rgba(15, 23, 42, 0.25));
                }

                .name {
                    fill: white;
                    font-size: 20px;
                    font-weight: 600;
                    text-anchor: middle;
                    pointer-events: none;
                }

                .role {
                    fill: white;
                    font-size: 16px;
                    text-anchor: middle;
                    opacity: 0.85;
                    pointer-events: none;
                }

                @media (max-width: 768px) {
                    .name {
                        font-size: 16px;
                    }
                    .role {
                        font-size: 13px;
                    }
                }
            </style>
        </defs>

        <!-- OWNER -->

        <rect
            class="box person"
            data-name="H. Hutomo Mandala Putra, SH"
            data-role="Owner"
            data-photo={tommy.src}
            x="245"
            y="0"
            width="260"
            height="90"
            rx="20"></rect>

        <text class="name" x="375" y="40">H. Hutomo Mandala Putra, SH</text>
        <text class="role" x="375" y="65">Owner</text>

        <!-- INTERNAL AUDITOR -->

        <line class="line" x1="375" y1="190" x2="255" y2="190"></line>

        <rect class="box" x="155" y="140" width="200" height="100" rx="20"
        ></rect>

        <text class="name" x="255" y="195">Internal Auditor</text>

        <line class="line" x1="375" y1="90" x2="375" y2="300"></line>

        <!-- Commissioner -->

        <line class="line" x1="350" y1="190" x2="400" y2="190"></line>
        <rect
            class="box person"
            data-type="multiple"
            data-names="Hery Mutohar|Sah Riza Novantiar"
            data-roles="President Commissioner|Commissioner"
            data-photos={`${heri.src}|${sahriza.src}`}
            x="390"
            y="140"
            width="260"
            height="100"
            rx="20"></rect>

        <text class="name" x="520" y="195">Commissioner</text>

        <!-- PRESIDENT DIRECTOR -->

        <rect
            class="box person"
            data-name="Tulus Widaryanto"
            data-role="President Director"
            data-photo={tulus.src}
            x="245"
            y="300"
            width="260"
            height="100"
            rx="20"></rect>

        <text class="name" x="375" y="345">Tulus Widaryanto</text>
        <text class="role" x="375" y="370">President Director</text>

        <line class="line" x1="375" y1="400" x2="375" y2="460"></line>

        <!-- SPLIT -->

        <line class="line" x1="260" y1="460" x2="490" y2="460"></line>

        <line class="line" x1="260" y1="460" x2="260" y2="510"></line>
        <line class="line" x1="490" y1="460" x2="490" y2="510"></line>

        <!-- OPERATION DIRECTOR -->

        <rect
            class="box person"
            data-name="Sonia Balqis Anshori"
            data-role="Operation Director"
            data-photo={sonia.src}
            x="105"
            y="510"
            width="260"
            height="100"
            rx="20"></rect>

        <text class="name" x="235" y="555">Sonia Balqis Anshori</text>
        <text class="role" x="235" y="580">Operation Director</text>

        <!-- TECHNICAL DIRECTOR -->

        <rect
            class="box person"
            data-name="Anggoro Ibnu Baskoro"
            data-role="Technical & Commercial Director"
            data-photo={anggoro.src}
            x="385"
            y="510"
            width="260"
            height="100"
            rx="20"></rect>

        <text class="name" x="515" y="555">Anggoro Ibnu Baskoro</text>
        <text class="role" x="515" y="580">Technical & Commercial Director</text
        >

        <line class="line" x1="260" y1="610" x2="260" y2="660"></line>
        <line class="line" x1="490" y1="610" x2="490" y2="660"></line>

        <!-- GM FINANCE -->

        <rect
            class="box person"
            data-name="Faqih Fauzi"
            data-role="GM Finance"
            data-photo={faqih.src}
            x="105"
            y="660"
            width="260"
            height="100"
            rx="20"></rect>

        <text class="name" x="235" y="705">Faqih Fauzi</text>
        <text class="role" x="235" y="730">GM Finance</text>

        <!-- GM SUPPLY CHAIN -->

        <rect
            class="box person"
            data-name="Yehezikel Yonathan"
            data-role="GM Supply Chain"
            data-photo={yehezkiel.src}
            x="385"
            y="660"
            width="260"
            height="100"
            rx="20"></rect>

        <text class="name" x="515" y="705">Yehezikel Yonathan</text>
        <text class="role" x="515" y="730">GM Supply Chain</text>
    </svg>
</div>

<style>
    .chart-wrapper {
        position: relative;
    }

    @media (max-width: 768px) {
        .chart-wrapper {
            height: 80svh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .chart-wrapper svg {
            height: 100%;
            width: auto;
            max-width: none;
        }
    }
    @media (max-width: 360px) {
        svg {
            transform: scale(1.15);
        }
        .chart-wrapper {
            overflow: visible;
        }
    }
</style>
