<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 reveal-group">
    <!-- Section Header -->
    <div class="text-center mb-14 reveal-group">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 reveal reveal-up">
        Contact & Service Inquiry
      </h2>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto reveal reveal-up">
        For fuel trading inquiries, marine bunker coordination, or operational
        collaboration, our commercial and technical teams are ready to assist.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid md:grid-cols-2 gap-12">
      <!-- LEFT: Contact Information -->
      <div class="space-y-10 reveal-group">
        <!-- Head Office -->
        <div class="border border-gray-200 rounded-xl p-8 reveal reveal-left">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Head Office</h3>

          <p class="text-gray-600 leading-relaxed">
            Gedung Granadi, Lt. 3, Sayap Utara<br />
            Jl. H.R. Rasuna Said, Kuningan<br />
            Jakarta Selatan 12950<br />
            Indonesia
          </p>

          <div class="mt-6 space-y-2 text-gray-700">
            <p>
              <span class="font-medium">Phone:</span>
              <a href="tel:+628131034402" class="text-blue-600 hover:underline">
                +62 813 1034 402
              </a>
            </p>
            <p>
              <span class="font-medium">Email:</span>
              <a
                href="mailto:admin@bumiasriprimapratama.com"
                class="text-blue-600 hover:underline"
              >
                admin@bumiasripratama.com
              </a>
            </p>
          </div>
        </div>

        <!-- Strategic Office -->
        <div class="border border-gray-200 rounded-xl p-8 reveal reveal-left">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">
            Strategic Office
          </h3>

          <p class="text-gray-600 leading-relaxed">
            Gayanti Office & Apartment <br />Jl. Gatot Subroto, Kuningan Barat <br
            /> Jakarta Selatan 12950,<br /> Indonesia.
          </p>

          <p class="mt-6 text-sm text-gray-500">
            Office visits are available by prior appointment.
          </p>
        </div>
      </div>

      <!-- RIGHT: Inquiry Form -->
      <div
        class="bg-gray-50 border border-gray-200 rounded-xl p-8 shadow-sm reveal reveal-right"
      >
        <h3 class="text-xl font-semibold text-gray-900 mb-6">
          Fuel & Marine Service Inquiry
        </h3>

        <form id="contactForm" class="space-y-5 reveal reveal-right">
          <!-- Honeypot -->
          <input type="text" name="website" class="hidden" />

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Full Name
            </label>
            <input
              type="text"
              name="name"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Company Name
            </label>
            <input
              type="text"
              name="company"
              class="w-full border border-gray-300 rounded-lg px-4 py-3"
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Email Address
              </label>
              <input
                type="email"
                name="email"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">
                Phone Number
              </label>
              <input
                type="tel"
                name="phone"
                class="w-full border border-gray-300 rounded-lg px-4 py-3"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Type of Service
            </label>
            <select
              name="service"
              class="w-full border border-gray-300 rounded-lg px-4 py-3"
            >
              <option>High Speed Diesel (HSD) Trading</option>
              <option>Marine Fuel Oil (MFO)</option>
              <option>Bunker / Ship-to-Ship (STS)</option>
              <option>Floating Storage Unit (FSU)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Message
            </label>
            <textarea
              name="message"
              rows="4"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-3"
            ></textarea>
          </div>

          <button
            id="submitBtn"
            type="submit"
            class="w-full bg-[#0077cc] hover:bg-[#0178d4] cursor-pointer text-white font-semibold py-3 rounded-lg transition flex items-center justify-center gap-2"
          >
            <span id="btnText">Request Quotation</span>

            <svg
              id="btnLoader"
              class="hidden animate-spin h-5 w-5"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="white"
                stroke-width="4"></circle>
              <path class="opacity-75" fill="white" d="M4 12a8 8 0 018-8v8z">
              </path>
            </svg>
          </button>
        </form>
        <div
          id="formSuccess"
          class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700"
        >
          Thank you. Your inquiry has been successfully sent. Our team will
          contact you shortly.
        </div>

        <div
          id="formError"
          class="hidden mt-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700"
        >
          Something went wrong. Please try again later.
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const button = document.getElementById(
    "submitBtn"
  ) as HTMLButtonElement | null;
  const btnText = document.getElementById("btnText");
  const loader = document.getElementById("btnLoader");

  const successBox = document.getElementById("formSuccess");
  const errorBox = document.getElementById("formError");

  if (form && button && btnText && loader && successBox && errorBox) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      successBox.classList.add("hidden");
      errorBox.classList.add("hidden");

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      button.disabled = true;
      loader.classList.remove("hidden");
      btnText.textContent = "Sending...";

      try {
        const res = await fetch("/api/contact", {
          method: "POST",

          headers: {
            "Content-Type": "application/json",
          },

          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.reset();
          successBox.classList.remove("hidden");
          successBox.scrollIntoView({ behavior: "smooth" });
        } else {
          errorBox.classList.remove("hidden");
        }
      } catch (err) {
        errorBox.classList.remove("hidden");
      }

      loader.classList.add("hidden");
      btnText.textContent = "Request Quotation";
      button.disabled = false;
    });
  }
</script>
