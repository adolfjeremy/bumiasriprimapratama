---
import ChartLg from "./ChartLg.astro";
import ChartSm from "./ChartSm.astro";
---

<section class="py-8 md:pb-12 md:pt-6 bg-white">
  <div class="max-w-6xl mx-auto px-0 lg:px-6 text-center reveal-group">
    <h2
      class="text-3xl md:text-4xl font-bold text-[#0F172A] mb-6 reveal reveal-up"
    >
      Structured Governance and Leadership
    </h2>

    <p
      class="text-base md:text-lg text-slate-600 max-w-3xl mx-auto mb-12 md:mb-16 reveal reveal-up"
    >
      As a fuel distribution company in Indonesia, BAPP remains focused on
      operational reliability, supply consistency, and long-term industry
      partnerships.
    </p>
    <div class="block md:hidden reveal reveal-zoom">
      <ChartSm />
    </div>
    <div class="large-chart reveal reveal-zoom">
      <ChartLg />
    </div>
  </div>
</section>

<!-- Preview Modal -->

<div id="org-preview" class="org-preview flex flex-row hidden">

  <div class="org-preview-card">
    <div>
      <img class="org-preview-img" />
    </div>
    <div class="preview-info">
      <h3 class="org-preview-name"></h3>
      <p class="org-preview-role"></p>
    </div>
  </div>

  <div class="org-preview-card">
    <div>
      <img class="org-preview-img" />
    </div>
    <div class="preview-info">
      <h3 class="org-preview-name"></h3>
      <p class="org-preview-role"></p>
    </div>
  </div>

</div>



<style>
/* overlay */

@media (max-width: 765px) {
  .large-chart {
    display: none;
  }
}

.org-preview {
  position: fixed;
  inset: 0;
  height: 100vh;  

  display: flex;
  align-items: center;
  justify-content: center;

  background: rgba(15, 23, 42, 0.55);
  z-index: 9999;

  opacity: 1;
  transition: opacity 0.25s ease;

  /* ⬇️ TAMBAHAN */
  gap: 20px;
  padding: 20px;
  flex-wrap: wrap;
}

.hidden {
  opacity: 0;
  pointer-events: none;
}

/* card */

.org-preview-card {
  width: 360px;
  max-width: 92vw;
  background: white;
  border-radius: 16px;
  padding: 0 0 16px 0;
  text-align: center;
  box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12),
    0 4px 10px rgba(15, 23, 42, 0.08);

  transform: translateY(18px) scale(0.97);
  opacity: 0;

  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
    opacity 0.25s ease;
}

.org-preview.show .org-preview-card {
  transform: translateY(0) scale(1);
  opacity: 1;
}

/* photo */

.org-preview-card img {
  width: 100%;
  height: auto;
  object-fit: cover;

  border-radius: 12px;
  margin-bottom: 18px;

  border: 3px solid #f1f5f9;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
}

/* name */

.org-preview-card h3 {
  font-size: 22px;
  font-weight: 700;
  color: #0f172a;

  margin-bottom: 6px;
  line-height: 1.25;
  letter-spacing: 0.2px;
}

/* role */

.org-preview-card p {
  font-size: 15px;
  color: #64748b;
  font-weight: 500;
}

/* ========================= */
/* 📱 MOBILE (STACK) */
/* ========================= */

@media (max-width: 768px) {

  .org-preview {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .org-preview-card {
    width: 100%;
    max-width: 320px; /* ⬅️ penting */
    padding: 20px;
    max-height: 50svh;
  }

  .org-preview-card img {
    width: 100%;
    height: auto;
    max-height: 32svh;   /* ⬅️ ini bikin image tidak kebesaran */
  object-fit: cover;
  }

  .org-preview-card h3 {
    font-size: 20px;
  }

  .name {
    font-size: 22px;
    font-weight: 700;
  }

  .role {
    font-size: 17px;
  }
}

/* ========================= */
/* 💻 DESKTOP (2 COLUMN) */
/* ========================= */

@media (min-width: 769px) {

  .org-preview {
    flex-direction: row; /* ⬅️ side by side */
  }

}
</style>

<script>
  const people = document.querySelectorAll(".person");

  const preview = document.getElementById("org-preview");
  const cards = document.querySelectorAll(".org-preview-card");

  const body = document.body;

  function showPreview(el) {
    const photo = el.dataset.photo;
    const personName = el.dataset.name;
    const personRole = el.dataset.role;

    const img = cards[0].querySelector(".org-preview-img");
    const name = cards[0].querySelector(".org-preview-name");
    const role = cards[0].querySelector(".org-preview-role");

    const preload = new Image();
    preload.src = photo;

    preload.onload = () => {
      img.src = photo;
      name.textContent = personName;
      role.textContent = personRole;

      // hide card ke-2
      cards[1].classList.add("hidden");

      showContainer();
    };
  }

  function showPreviewMultiple(el) {
    const names = el.dataset.names.split("|");
    const roles = el.dataset.roles.split("|");
    const photos = el.dataset.photos.split("|");

    names.forEach((n, i) => {
      const card = cards[i];

      const img = card.querySelector(".org-preview-img");
      const name = card.querySelector(".org-preview-name");
      const role = card.querySelector(".org-preview-role");

      img.src = photos[i];
      name.textContent = n;
      role.textContent = roles[i];

      card.classList.remove("hidden");
    });

    showContainer();
  }

  function showContainer() {
    body.classList.add("freze");
    preview.classList.remove("hidden");

    requestAnimationFrame(() => {
      preview.classList.add("show");
    });
  }

  function hidePreview() {
    preview.classList.remove("show");
    body.classList.remove("freze");

    setTimeout(() => {
      preview.classList.add("hidden");

      // reset semua card
      cards.forEach((card) => {
        card.classList.remove("hidden");

        card.querySelector(".org-preview-img").src = "";
        card.querySelector(".org-preview-name").textContent = "";
        card.querySelector(".org-preview-role").textContent = "";
      });
    }, 200);
  }

  people.forEach((el) => {
    el.addEventListener("click", (e) => {
      e.stopPropagation();

      if (el.dataset.type === "multiple") {
        showPreviewMultiple(el);
      } else {
        showPreview(el);
      }
    });
  });

  document.addEventListener("click", (e) => {
    if (!e.target.closest(".person")) {
      hidePreview();
    }
  });

  // preload
  people.forEach((el) => {
    if (el.dataset.photo) {
      const img = new Image();
      img.src = el.dataset.photo;
    }

    if (el.dataset.photos) {
      el.dataset.photos.split("|").forEach((src) => {
        const img = new Image();
        img.src = src;
      });
    }
  });
</script>
