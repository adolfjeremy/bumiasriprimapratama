---
import ChartLg from "./ChartLg.astro";
import ChartSm from "./ChartSm.astro";
---

<section class="py-8 md:pb-12 md:pt-6 bg-white">
  <div class="max-w-6xl mx-auto px-0 lg:px-6 text-center reveal-group">
    <h2
      class="text-3xl md:text-4xl font-bold text-[#0F172A] mb-6 reveal reveal-up"
    >
      Structured Governance and Leadership
    </h2>

    <p
      class="text-base md:text-lg text-slate-600 max-w-3xl mx-auto mb-12 md:mb-16 reveal reveal-up"
    >
      As a fuel distribution company in Indonesia, BAPP remains focused on
      operational reliability, supply consistency, and long-term industry
      partnerships.
    </p>
    <div class="block md:hidden reveal reveal-zoom">
      <ChartSm />
    </div>
    <div class="large-chart reveal reveal-zoom">
      <ChartLg />
    </div>
  </div>
</section>

<!-- Preview Modal -->

<div id="org-preview" class="org-preview hidden">
  <div id="org-preview-card" class="org-preview-card">
    <div>
      <img id="org-preview-img" />
    </div>

    <div class="preview-info">
      <h3 id="org-preview-name"></h3>
      <p id="org-preview-role"></p>
    </div>
  </div>
</div>

<style>
  /* overlay */

  @media (max-width: 765px) {
    .large-chart {
      display: none;
    }
  }

  .org-preview {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;

    background: rgba(15, 23, 42, 0.55);

    z-index: 9999;

    opacity: 1;
    transition: opacity 0.25s ease;
  }

  .hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* card */

  .org-preview-card {
    width: 360px;
    max-width: 92vw;
    background: white;
    border-radius: 16px;
    padding: 0 0 16px 0;
    text-align: center;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12),
      0 4px 10px rgba(15, 23, 42, 0.08);
    transform: translateY(18px) scale(0.97);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.25s ease;
  }

  .org-preview.show .org-preview-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  /* photo */

  .org-preview-card img {
    width: 100%;
    height: auto;

    object-fit: cover;

    border-radius: 12px;

    margin-bottom: 18px;

    border: 3px solid #f1f5f9;

    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
  }

  /* name */

  .org-preview-card h3 {
    font-size: 22px;
    font-weight: 700;

    color: #0f172a;

    margin-bottom: 6px;

    line-height: 1.25;

    letter-spacing: 0.2px;
  }

  /* role */

  .org-preview-card p {
    font-size: 15px;

    color: #64748b;

    font-weight: 500;
  }

  /* mobile */

  @media (max-width: 768px) {
    .org-preview-card {
      width: 92vw;

      padding: 24px;
    }

    .org-preview-card img {
      width: 100%;
      height: auto;
    }

    .org-preview-card h3 {
      font-size: 20px;
    }
    .name {
      font-size: 22px;
      font-weight: 700;
    }

    .role {
      font-size: 17px;
    }
  }
</style>

<script>
  const people = document.querySelectorAll(".person");

  const preview = document.getElementById("org-preview");
  const img = document.getElementById("org-preview-img");
  const name = document.getElementById("org-preview-name");
  const role = document.getElementById("org-preview-role");
  const body = document.body;

  function showPreview(el) {
    const photo = el.dataset.photo;
    const personName = el.dataset.name;
    const personRole = el.dataset.role;

    const preload = new Image();

    preload.src = photo;

    preload.onload = () => {
      img.src = photo;
      name.textContent = personName;
      role.textContent = personRole;
      body.classList.add("freze");

      preview.classList.remove("hidden");

      requestAnimationFrame(() => {
        preview.classList.add("show");
      });
    };
  }

  function hidePreview() {
    preview.classList.remove("show");
    body.classList.remove("freze");

    setTimeout(() => {
      preview.classList.add("hidden");

      // reset content supaya tidak flicker
      img.src = "";
      name.textContent = "";
      role.textContent = "";
    }, 200);
  }

  people.forEach((el) => {
    el.addEventListener("click", (e) => {
      e.stopPropagation();

      showPreview(el);
    });
  });

  document.addEventListener("click", (e) => {
    if (!e.target.closest(".person")) {
      hidePreview();
    }
  });

  const photos = document.querySelectorAll(".person");

  photos.forEach((el) => {
    const img = new Image();
    img.src = el.dataset.photo;
  });
</script>
