---
import tommy from "../assets/images/tommy.png";
import heri from "../assets/images/heri.png";
import sahriza from "../assets/images/sahriza.png";
import tulus from "../assets/images/tulus.png";
import sonia from "../assets/images/sonia.png";
import anggoro from "../assets/images/anggoro.png";
import faqih from "../assets/images/faqih.png";
import yehezkiel from "../assets/images/yehezkiel.png";
---

<div class="w-full max-w-5xl mx-auto overflow-visible">
    <svg viewBox="-80 0 1160 1000" class="w-full h-auto overflow-visible">
        <defs>
            <style>
                .line {
                    stroke: #1e293b;
                    stroke-width: 4;
                }

                .box {
                    fill: #0f2e4d;
                    transition: transform 0.25s ease, filter 0.25s ease;
                    transform-box: fill-box;
                    transform-origin: center;
                    cursor: pointer;
                }

                .box:hover {
                    transform: scale(1.05);
                    filter: drop-shadow(0px 12px 24px rgba(15, 23, 42, 0.25));
                }

                .name {
                    fill: white;
                    font-size: 20px;
                    font-weight: 600;
                    text-anchor: middle;
                    pointer-events: none;
                }

                .role {
                    fill: white;
                    font-size: 16px;
                    text-anchor: middle;
                    opacity: 0.85;
                    pointer-events: none;
                }

                @media (max-width: 768px) {
                    .name {
                        font-size: 16px;
                    }
                    .role {
                        font-size: 13px;
                    }
                }
            </style>
        </defs>

        <!-- Owner -->

        <rect
            class="box person"
            data-name="H. Hutomo Mandala Putra"
            data-role="Owner"
            data-photo={tommy.src}
            x="350"
            y="0"
            width="300"
            height="90"
            rx="20"></rect>

        <text class="name" x="500" y="40">H. Hutomo Mandala Putra</text>
        <text class="role" x="500" y="65">Owner</text>

        <line class="line" x1="500" y1="90" x2="500" y2="140"></line>

        <!-- President Commissioner -->

        <rect
            class="box person"
            data-name="Hery Mutohar"
            data-role="President Commissioner"
            data-photo={heri.src}
            x="350"
            y="140"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="500" y="185">Hery Mutohar</text>
        <text class="role" x="500" y="210">President Commissioner</text>

        <line class="line" x1="500" y1="240" x2="500" y2="300"></line>

        <!-- Commissioner -->

        <rect
            class="box person"
            data-name="Sah Riza Novantiar"
            data-role="Commissioner"
            data-photo={sahriza.src}
            x="350"
            y="300"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="500" y="345">Sah Riza Novantiar</text>
        <text class="role" x="500" y="370">Commissioner</text>

        <line class="line" x1="500" y1="400" x2="500" y2="460"></line>

        <!-- Internal Auditor (no photo) -->

        <line class="line" x1="500" y1="460" x2="280" y2="460"></line>

        <rect class="box" x="0" y="410" width="280" height="100" rx="20"></rect>

        <text class="name" x="140" y="460">Internal Auditor</text>

        <line class="line" x1="500" y1="460" x2="500" y2="520"></line>

        <!-- President Director -->

        <rect
            class="box person"
            data-name="Tulus Widaryanto"
            data-role="President Director"
            data-photo={tulus.src}
            x="350"
            y="520"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="500" y="565">Tulus Widaryanto</text>
        <text class="role" x="500" y="590">President Director</text>

        <line class="line" x1="500" y1="620" x2="500" y2="680"></line>

        <!-- Split -->

        <line class="line" x1="200" y1="680" x2="800" y2="680"></line>
        <line class="line" x1="200" y1="680" x2="200" y2="730"></line>
        <line class="line" x1="800" y1="680" x2="800" y2="730"></line>

        <!-- Operation Director -->

        <rect
            class="box person"
            data-name="Sonia Balqis Anshori"
            data-role="Operation Director"
            data-photo={sonia.src}
            x="50"
            y="730"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="200" y="775">Sonia Balqis Anshori</text>
        <text class="role" x="200" y="800">Operation Director</text>

        <!-- Technical Director -->

        <rect
            class="box person"
            data-name="Anggoro Ibnu Baskoro"
            data-role="Technical & Commercial Director"
            data-photo={anggoro.src}
            x="650"
            y="730"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="800" y="775">Anggoro Ibnu Baskoro</text>
        <text class="role" x="800" y="800">Technical & Commercial Director</text
        >

        <line class="line" x1="200" y1="830" x2="200" y2="880"></line>
        <line class="line" x1="800" y1="830" x2="800" y2="880"></line>

        <!-- GM Finance -->

        <rect
            class="box person"
            data-name="Faqih Fauzi"
            data-role="GM Finance"
            data-photo={faqih.src}
            x="50"
            y="880"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="200" y="925">Faqih Fauzi</text>
        <text class="role" x="200" y="950">GM Finance</text>

        <!-- GM Supply Chain -->

        <rect
            class="box person"
            data-name="Yehezikel Yonathan"
            data-role="GM Supply Chain"
            data-photo={yehezkiel.src}
            x="650"
            y="880"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="800" y="925">Yehezikel Yonathan</text>
        <text class="role" x="800" y="950">GM Supply Chain</text>
    </svg>
</div>
