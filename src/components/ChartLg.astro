---
import tommy from "../assets/images/tommy.png";
import heri from "../assets/images/heri.png";
import sahriza from "../assets/images/sahriza.png";
import tulus from "../assets/images/tulus.png";
import sonia from "../assets/images/sonia.png";
import anggoro from "../assets/images/anggoro.png";
import faqih from "../assets/images/faqih.png";
import yehezkiel from "../assets/images/yehezkiel.png";
---

<div class="chart-wrapper w-full max-w-5xl mx-auto">
    <svg viewBox="-80 0 1160 1000" class="w-full h-auto overflow-visible">
        <defs>
            <style>
                .line {
                    stroke: #1e293b;
                    stroke-width: 4;
                }

                .box {
                    fill: #0f2e4d;
                    transition: transform 0.25s ease, filter 0.25s ease;
                    transform-box: fill-box;
                    transform-origin: center;
                    cursor: pointer;
                }

                .box:hover {
                    transform: scale(1.05);
                    filter: drop-shadow(0px 12px 24px rgba(15, 23, 42, 0.25));
                }

                .name {
                    fill: white;
                    font-size: 20px;
                    font-weight: 600;
                    text-anchor: middle;
                    pointer-events: none;
                }

                .role {
                    fill: white;
                    font-size: 16px;
                    text-anchor: middle;
                    opacity: 0.85;
                    pointer-events: none;
                }

                @media (max-width: 768px) {
                    .name {
                        font-size: 16px;
                    }
                    .role {
                        font-size: 13px;
                    }
                }
            </style>
        </defs>

        <!-- Owner -->

        <rect
            class="box person"
            data-name="H. Hutomo Mandala Putra, SH"
            data-role="Owner"
            data-photo={tommy.src}
            x="325"
            y="0"
            width="350"
            height="90"
            rx="20"></rect>

        <text class="name" x="500" y="40">H. Hutomo Mandala Putra, SH</text>
        <text class="role" x="500" y="65">Owner</text>

        <line class="line" x1="500" y1="90" x2="500" y2="140"></line>

        <!-- Internal Auditor -->

        <line class="line" x1="500" y1="140" x2="280" y2="140"></line>

        <rect class="box" x="0" y="90" width="280" height="100" rx="20"></rect>

        <text class="name" x="140" y="145">Internal Auditor</text>

        <line class="line" x1="500" y1="140" x2="500" y2="200"></line>

        <!-- Commisioner -->
        <rect
        class="box person"
        data-type="multiple"
        data-names="Hery Mutohar|Sah Riza Novantiar"
        data-roles="President Commissioner|Commissioner"
        data-photos={`${heri.src}|${sahriza.src}`}
        x="700"
        y="90"
        width="300"
        height="100"
        rx="20"></rect>

        <text class="name" x="850" y="145">Commissioner</text
        >

        <line class="line" x1="500" y1="140" x2="700" y2="140"></line>
        <!-- <line class="line" x1="800" y1="830" x2="800" y2="880"></line> -->

        <!-- President Director -->

        <rect
            class="box person"
            data-name="Tulus Widaryanto"
            data-role="President Director"
            data-photo={tulus.src}
            x="350"
            y="200"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="500" y="245">Tulus Widaryanto</text>
        <text class="role" x="500" y="270">President Director</text>

        <line class="line" x1="500" y1="300" x2="500" y2="360"></line>

        <!-- Split -->

        <line class="line" x1="200" y1="360" x2="800" y2="360"></line>
        <line class="line" x1="200" y1="360" x2="200" y2="410"></line>
        <line class="line" x1="800" y1="360" x2="800" y2="410"></line>

        <!-- Operation Director -->

        <rect
            class="box person"
            data-name="Sonia Balqis Anshori"
            data-role="Operation Director"
            data-photo={sonia.src}
            x="50"
            y="410"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="200" y="455">Sonia Balqis Anshori</text>
        <text class="role" x="200" y="480">Operation Director</text>

        <!-- Technical Director -->

        <rect
            class="box person"
            data-name="Anggoro Ibnu Baskoro"
            data-role="Technical & Commercial Director"
            data-photo={anggoro.src}
            x="650"
            y="410"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="800" y="455">Anggoro Ibnu Baskoro</text>
        <text class="role" x="800" y="480">Technical & Commercial Director</text
        >

        <line class="line" x1="200" y1="510" x2="200" y2="560"></line>
        <line class="line" x1="800" y1="510" x2="800" y2="560"></line>

        <!-- GM Finance -->

        <rect
            class="box person"
            data-name="Faqih Fauzi"
            data-role="GM Finance"
            data-photo={faqih.src}
            x="50"
            y="560"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="200" y="605">Faqih Fauzi</text>
        <text class="role" x="200" y="630">GM Finance</text>

        <!-- GM Supply Chain -->

        <rect
            class="box person"
            data-name="Yehezikel Yonathan"
            data-role="GM Supply Chain"
            data-photo={yehezkiel.src}
            x="650"
            y="560"
            width="300"
            height="100"
            rx="20"></rect>

        <text class="name" x="800" y="605">Yehezikel Yonathan</text>
        <text class="role" x="800" y="630">GM Supply Chain</text>
    </svg>
</div>

<style>
    .chart-wrapper {
        position: relative;
        width: 100%;
    }

    .chart-wrapper svg {
        width: 100%;
        height: auto;
        display: block;
    }

    /* mobile only */
    @media (max-width: 768px) {
        .chart-wrapper {
            height: 80svh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .chart-wrapper svg {
            height: 100%;
            width: auto;
            max-width: none;
        }
    }
</style>