---
import { Image } from "astro:assets";
import Button from "./Button.astro";

const {
  title,
  subtitle,
  background,
  alt = "image",
  isButton = true,
} = Astro.props;
---

<section
  class="relative h-screen flex items-center overflow-hidden px-5 md:px-16 lg:px-20 pt-28 md:pt-32 pb-20"
>
  <!-- background -->
  <Image
    src={background}
    alt={alt}
    class="hero-bg absolute inset-0 w-full h-full object-cover"
    quality={70}
    format="webp"
    loading="eager"
    fetchpriority="high"
  />

  <!-- gradient overlay -->
  <div class="absolute inset-0 hero-overlay"></div>

  <!-- container -->
  <div class="relative z-10 w-full max-w-[1280px] mx-auto">
    <div
      class="max-w-[820px] reveal-group text-left mx-auto lg:mx-0 text-white"
    >
      <h1 class="hero-title reveal">
        {title}
      </h1>

      <p class="hero-subtitle reveal">
        {subtitle}
      </p>

      {
        isButton && (
          <div class="mt-10 flex justify-start lg:justify-start reveal">
            <Button href="/contact" text="Request Quotation" />
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero-title {
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;

    font-size: clamp(1.5rem, 4vw, 3rem);
  }

  .hero-subtitle {
    margin-top: 1.5rem;
    max-width: 640px;

    font-size: clamp(0.9375rem, 1.25vw, 1.215rem);
    line-height: 1.7;

    color: rgb(229 231 235);
  }

  .hero-overlay {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      rgba(0, 0, 0, 0.1) 80%
    );
  }

  .hero-bg {
    animation: heroZoom 18s ease-in-out infinite alternate;
  }

  @keyframes heroZoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }
</style>
