---
import { Image } from "astro:assets";
import Button from "./Button.astro";

const {
  title,
  subtitle,
  background,
  alt = "image",
  isButton = true,
} = Astro.props;
---

<section
  class="relative min-h-[90svh] lg:min-h-screen flex items-center overflow-hidden
  px-5 md:px-16 lg:px-20 pt-28 md:pt-32 pb-20"
>
  <!-- background -->
  <Image
    src={background}
    alt={alt}
    class="hero-bg absolute inset-0 w-full h-full object-cover"
    quality={70}
    format="webp"
    loading="eager"
    fetchpriority="high"
  />

  <!-- gradient overlay -->
  <div class="absolute inset-0 hero-overlay"></div>

  <!-- container -->
  <div class="relative z-10 w-full max-w-[1280px] mx-auto">
    <div
      class="max-w-xl md:max-w-2xl lg:max-w-3xl
      text-center lg:text-left
      mx-auto lg:mx-0 text-white"
    >
      <h1
        class="text-[32px] md:text-[48px] lg:text-[60px]
        font-semibold leading-[1.15] tracking-tight"
      >
        {title}
      </h1>

      <p
        class="mt-6 text-[16px] md:text-[18px]
        text-gray-200 leading-relaxed
        max-w-xl mx-auto lg:mx-0"
      >
        {subtitle}
      </p>

      {
        isButton && (
          <div class="mt-10 flex justify-center lg:justify-start">
            <Button href="/contact" text="Request Quotation" />
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero-overlay {
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.45) 40%,
      rgba(0, 0, 0, 0.2) 70%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .hero-bg {
    animation: heroZoom 18s ease-in-out infinite alternate;
  }

  @keyframes heroZoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }
</style>
