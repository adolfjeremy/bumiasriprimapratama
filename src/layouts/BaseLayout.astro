---
const {
  title,
  description,
  image = "/logo.png",
  url = Astro.url.pathname,
  type = "website",
  schema,
} = Astro.props;

const fullUrl = `https://bumiasriprimapratama.com${url}`;
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullUrl} />
    <meta
      property="og:image"
      content={`https://bumiasriprimapratama.com${image}`}
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={`https://bumiasriprimapratama.com${image}`}
    />

    <!-- Favicon -->
    <link rel="icon" href="/logo-sm.png" />
    <!-- Schema Injection -->
    {
      schema &&
        schema.map((item: any) => {
          const schemaItem = JSON.stringify(item);

          return <script type="application/ld+json" set:html={schemaItem} />;
        })
    }
  </head>

  <body class="bg-white text-gray-900 antialiased">
    <Navbar />
    <slot />
    <Footer />
    <script>
      function initReveal() {
        const elements = document.querySelectorAll(".reveal");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
              } else {
                // hanya reset jika benar-benar jauh dari viewport
                const rect = entry.boundingClientRect;

                if (rect.top > window.innerHeight || rect.bottom < 0) {
                  entry.target.classList.remove("is-visible");
                }
              }
            });
          },
          {
            threshold: 0.25,
            rootMargin: "0px 0px -120px 0px",
          }
        );

        elements.forEach((el) => {
          const parent = el.closest(".reveal-group");

          if (parent) {
            const siblings = [...parent.querySelectorAll(".reveal")];
            const index = siblings.indexOf(el);

            const delay = index * 0.08;

            el.style.setProperty("--reveal-delay", `${delay}s`);
          }

          observer.observe(el);
        });
      }

      document.addEventListener("DOMContentLoaded", initReveal);
    </script>
  </body>
</html>
